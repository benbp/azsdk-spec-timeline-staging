{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Azure SDK Service Timeline",
  "description": "Data model for visualizing the full timeline of a TypeSpec service across multiple spec PRs, SDK PRs, and releases.",
  "type": "object",
  "required": ["type", "service", "specPath", "startDate", "endDate", "specPRs", "sdkPRs"],
  "properties": {
    "type": {
      "type": "string",
      "const": "service-timeline",
      "description": "Discriminator to distinguish from per-release timelines"
    },
    "service": {
      "type": "string",
      "description": "Service name (e.g. DurableTask, NetApp)"
    },
    "specPath": {
      "type": "string",
      "description": "TypeSpec project path relative to azure-rest-api-specs (e.g. specification/durabletask/DurableTask.Management)"
    },
    "namespace": {
      "type": ["string", "null"],
      "description": "TypeSpec namespace (e.g. Microsoft.DurableTask)"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this data was generated"
    },
    "lookback": {
      "type": "object",
      "properties": {
        "requestedDays": { "type": "integer" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" }
      }
    },
    "startDate": {
      "type": "string",
      "format": "date-time",
      "description": "Earliest event timestamp across all included release cycles"
    },
    "endDate": {
      "type": "string",
      "format": "date-time",
      "description": "Latest event timestamp (or now for in-flight cycles)"
    },
    "packages": {
      "type": "object",
      "description": "Package metadata per language from TypeSpec metadata",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "serviceDir": { "type": "string" },
          "packageDir": { "type": "string" },
          "repo": { "type": "string" },
          "emitter": { "type": "string" }
        }
      }
    },
    "specPRs": {
      "type": "array",
      "items": { "$ref": "schema.json#/definitions/pullRequest" },
      "description": "All spec PRs whose creation falls within the lookback window"
    },
    "sdkPRs": {
      "type": "object",
      "description": "SDK PRs grouped by language",
      "properties": {
        "Python": { "type": "array", "items": { "$ref": "schema.json#/definitions/pullRequest" } },
        "Java": { "type": "array", "items": { "$ref": "schema.json#/definitions/pullRequest" } },
        "Go": { "type": "array", "items": { "$ref": "schema.json#/definitions/pullRequest" } },
        ".NET": { "type": "array", "items": { "$ref": "schema.json#/definitions/pullRequest" } },
        "JavaScript": { "type": "array", "items": { "$ref": "schema.json#/definitions/pullRequest" } }
      }
    },
    "releaseWindows": {
      "type": "array",
      "items": { "$ref": "#/definitions/releaseWindow" }
    },
    "summary": { "$ref": "#/definitions/serviceSummary" },
    "insights": {
      "type": "array",
      "items": { "$ref": "schema.json#/definitions/insight" }
    }
  },
  "definitions": {
    "releaseWindow": {
      "type": "object",
      "required": ["id", "label", "startDate", "endDate"],
      "properties": {
        "id": { "type": "string", "description": "Unique window identifier (e.g. rw-1)" },
        "label": { "type": "string", "description": "Human-readable label (e.g. v2026-02-01 Release)" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "specPRNumbers": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Spec PR numbers in this window"
        },
        "sdkPRNumbers": {
          "type": "object",
          "description": "SDK PR numbers per language in this window",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "integer" }
          }
        },
        "summary": {
          "type": "object",
          "description": "Per-window metrics (same structure as single-release summary)",
          "properties": {
            "totalDurationDays": { "type": ["number", "null"] },
            "specPRDays": { "type": ["number", "null"] },
            "pipelineGapDays": { "type": ["number", "null"] },
            "totalNags": { "type": "integer" },
            "totalManualFixes": { "type": "integer" },
            "totalUniqueReviewers": { "type": "integer" },
            "totalReviewWaitDays": { "type": "number" },
            "totalReviewWaitCycles": { "type": "integer" }
          }
        }
      }
    },
    "serviceSummary": {
      "type": "object",
      "properties": {
        "totalSpecPRs": { "type": "integer" },
        "totalSDKPRs": { "type": "integer" },
        "totalReleases": { "type": "integer" },
        "avgCycleTimeDays": { "type": ["number", "null"], "description": "Avg spec PR creation → all SDK PRs merged" },
        "avgPipelineGapDays": { "type": ["number", "null"] },
        "avgReviewWaitDays": { "type": ["number", "null"] },
        "totalNags": { "type": "integer" },
        "totalManualFixes": { "type": "integer" },
        "totalToolCalls": { "type": "integer" },
        "toolCallSuccessRate": { "type": ["number", "null"] },
        "languageBreakdown": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "prCount": { "type": "integer" },
              "avgDays": { "type": ["number", "null"] },
              "releaseCount": { "type": "integer" }
            }
          }
        },
        "topReviewers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "login": { "type": "string" },
              "reviewCount": { "type": "integer" }
            }
          },
          "description": "Top 10 reviewers by activity"
        },
        "automationRate": {
          "type": ["number", "null"],
          "description": "Fraction of SDK PRs that were automated (0-1)"
        }
      }
    }
  }
}
